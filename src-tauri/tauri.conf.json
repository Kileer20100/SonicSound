{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SonicSound",
  "version": "0.1.0",
  "identifier": "SonicSound",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SonicSound",
        "width": 800,
        "height": 600,
        "visible": false,
        "resizable": true
        
      },
      {
        "label": "splashscreen",
        "title": "Loading...",
        "width": 400,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "url": "/splash_page"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
